# 4x4 matrix (4 students, 4 subjects)
student_scores = [
    [85, 78, 90, 88],
    [92, 81, 87, 79],
    [76, 85, 80, 90],
    [89, 88, 91, 84]
]

# Subject names
subjects = ["Math", "Science", "English", "History"]

average_scores = []

# Calculate average score for each subject
for col in range(4):
    total = 0
    for row in range(4):
        total += student_scores[row][col]
    average = total / 4
    average_scores.append(average)

print("Average Score for Each Subject:")
for i in range(4):
    print(subjects[i], ":", average_scores[i])

# Find subject with highest average score
highest_average = average_scores[0]
highest_subject = subjects[0]

for i in range(1, 4):
    if average_scores[i] > highest_average:
        highest_average = average_scores[i]
        highest_subject = subjects[i]

print("\nSubject with Highest Average Score:")
print(highest_subject)
print("Average Score:", highest_average)
